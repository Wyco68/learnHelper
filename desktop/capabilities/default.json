{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions, including events for the splash screen",
  "windows": ["main", "splash"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "vaultd", "sidecar": true },
        { "name": "node", "sidecar": true, "args": ["server.js"] }
      ]
    }
  ]
}
