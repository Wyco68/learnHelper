# Personal lesson vault — never shipped in the public template.
# Each user's own subjects/lessons live here, generated locally by savelesson.
/vault/

# Built binary — built locally at setup time (see README), not committed.
tools/vaultd/vaultd.exe
tools/vaultd/vaultd

# Local Claude subscription credential (encrypted) — never committed.
/.claude-token.enc
/.claude-secret.key

# Editor/tooling local state
.impeccable/
**/.impeccable/

# Next.js web app
/node_modules/
/.next/
.env.local
